<local:DinaWindow x:Class="DinaGameEngine.Views.CreatingProjectWindow"
        xmlns:local="clr-namespace:DinaGameEngine.Themes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:enums="clr-namespace:DinaGameEngine.Common.Enums;assembly=DinaGameEngine.Common"
        xmlns:ext="clr-namespace:DinaGameEngine.Extensions"
        Title="{ext:Translate Key=CreatingProject_Title}"
        Height="150" Width="400"
        Style="{StaticResource DinaWindowStyle}"
        TitleBarButtons="{x:Static enums:TitleBarButtons.None}"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="16" VerticalAlignment="Center">
        <TextBlock Text="{Binding Message}" FontSize="14"
                   TextWrapping="Wrap" Margin="0,0,0,12"/>
        <ProgressBar IsIndeterminate="True" Height="10"
                     Foreground="DarkViolet"/>
    </StackPanel>
</local:DinaWindow>
