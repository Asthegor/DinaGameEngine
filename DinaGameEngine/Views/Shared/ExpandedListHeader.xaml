<UserControl x:Class="DinaGameEngine.Views.Shared.ExpandedListHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DinaGameEngine.Views.Shared"
             mc:Ignorable="d">
    <Grid Margin="0,2,0,2" Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0"
                Content="{x:Static local:ExpandedListHeader.ChevronDownIcon}"
                FontFamily="Segoe Fluent Icons" FontSize="12"
                Command="{Binding ToggleExpandCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Width="24" Height="24">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource GhostFooterButton}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Content" Value="{x:Static local:ExpandedListHeader.ChevronUpIcon}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <TextBlock Grid.Column="1"
                   Text="{Binding Header, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   VerticalAlignment="Center" Margin="4,0,0,0"
                   Foreground="DimGray" FontSize="11">
            <TextBlock.InputBindings>
                <MouseBinding MouseAction="LeftClick"
                              Command="{Binding ToggleExpandCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </TextBlock.InputBindings>
        </TextBlock>

        <Button Grid.Column="2"
                Content="{x:Static local:ExpandedListHeader.AddIcon}"
                FontFamily="Segoe Fluent Icons" FontSize="12"
                Command="{Binding AddCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Width="24" Height="24" Margin="0,0,4,0"
                Style="{DynamicResource GhostFooterButton}"/>
    </Grid>
</UserControl>
