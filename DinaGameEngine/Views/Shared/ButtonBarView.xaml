<UserControl x:Class="DinaGameEngine.Views.Shared.ButtonBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DinaGameEngine.Views.Shared"
             xmlns:common="clr-namespace:DinaGameEngine.Common;assembly=DinaGameEngine.Common"
             xmlns:enums="clr-namespace:DinaGameEngine.Common.Enums;assembly=DinaGameEngine.Common"
             xmlns:converters="clr-namespace:DinaGameEngine.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:NullToThicknessConverter x:Key="NullToThicknessConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToStringValueConverter x:Key="BoolToStringValueConverter"/>
        <converters:ControlHorizontalAlignmentToHorizontalAlignmentConverter x:Key="ControlHorizontalAlignmentToHorizontalAlignmentConverter"/>
        <converters:ControlVerticalAlignmentToVerticalAlignmentConverter x:Key="ControlVerticalAlignmentToVerticalAlignmentConverter"/>
        <converters:StringToColumnSpanConverter x:Key="StringToColumnSpanConverter"/>
        <converters:ControlHorizontalAlignmentToGridLengthConverter x:Key="ControlHorizontalAlignmentToGridLengthConverter"/>
        <converters:IconToMarginConverter x:Key="IconToMarginConverter"/>
        <converters:LabelVisibilityConverter x:Key="LabelVisibilityConverter"/>
    </UserControl.Resources>
    <ItemsControl ItemsSource="{Binding Buttons}"
                  HorizontalAlignment="{Binding HorizontalAlignment}"
                  VerticalAlignment="{Binding VerticalAlignment}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <UniformGrid Rows="{Binding DataContext.Rows, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                             Columns="{Binding DataContext.Columns, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemContainerStyle>
            <Style TargetType="ContentPresenter">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
            </Style>
        </ItemsControl.ItemContainerStyle>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Button Command="{Binding Command}" Margin="4" Padding="16,8"
                        HorizontalContentAlignment="{Binding ContentHorizontalAlignment,
                                                     Converter={StaticResource ControlHorizontalAlignmentToHorizontalAlignmentConverter}}"
                        VerticalContentAlignment="{Binding ContentVerticalAlignment,
                                                   Converter={StaticResource ControlVerticalAlignmentToVerticalAlignmentConverter}}"
                        Height="{Binding DataContext.ButtonHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GhostFooterButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Role}" Value="{x:Static enums:ButtonRole.Primary}">
                                    <Setter Property="Background" Value="DarkViolet"/>
                                    <Setter Property="BorderBrush" Value="DarkViolet"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Tag" Value="#532E80"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Role}" Value="{x:Static enums:ButtonRole.Secondary}">
                                    <Setter Property="BorderBrush" Value="OrangeRed"/>
                                    <Setter Property="Foreground" Value="OrangeRed"/>
                                    <Setter Property="Tag" Value="#FFECB3"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Role}" Value="{x:Static enums:ButtonRole.Neutral}">
                                    <Setter Property="BorderBrush" Value="DarkViolet"/>
                                    <Setter Property="Foreground" Value="DarkViolet"/>
                                    <Setter Property="Tag" Value="#F3E5F5"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource Self}}" Value="False">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Gray"/>
                                    <Setter Property="Foreground" Value="Gray"/>
                                    <Setter Property="Tag" Value="#F5F5F5"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <!--<StackPanel Orientation="Horizontal">-->
                    <Grid HorizontalAlignment="{Binding ContentHorizontalAlignment,
                                                       Converter={StaticResource ControlHorizontalAlignmentToHorizontalAlignmentConverter}}"
                          VerticalAlignment="{Binding ContentVerticalAlignment,
                                              Converter={StaticResource ControlVerticalAlignmentToVerticalAlignmentConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding ContentHorizontalAlignment, 
                                                      Converter={StaticResource ControlHorizontalAlignmentToGridLengthConverter}}"/>
                            <ColumnDefinition Width="{Binding ContentHorizontalAlignment, 
                                                      Converter={StaticResource ControlHorizontalAlignmentToGridLengthConverter}}"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Column="0" Grid.Row="0"
                                   Text="{Binding Icon}" 
                                   FontSize="{Binding IconSize}" FontFamily="Segoe Fluent Icons"
                                   FontWeight="{Binding IconWeightStr}"
                                   HorizontalAlignment="{Binding LeftIconHorizontalAlignment, Converter={StaticResource ControlHorizontalAlignmentToHorizontalAlignmentConverter}}"
                                   VerticalAlignment="{Binding LeftIconVerticalAlignment, Converter={StaticResource ControlVerticalAlignmentToVerticalAlignmentConverter}}"
                                   Visibility="{Binding IsIconLeft, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Margin="{Binding Label, Converter={StaticResource NullToThicknessConverter}}"/>
                        <TextBlock Grid.Column="{Binding IsIconLeft, Converter={StaticResource BoolToStringValueConverter}}"
                                   Grid.ColumnSpan="{Binding Icon, Converter={StaticResource StringToColumnSpanConverter}}"
                                   Grid.Row="0"
                                   Text="{Binding Label}"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="{Binding LabelHorizontalAlignment, Converter={StaticResource ControlHorizontalAlignmentToHorizontalAlignmentConverter}}"
                                   VerticalAlignment="{Binding LabelVerticalAlignment, Converter={StaticResource ControlVerticalAlignmentToVerticalAlignmentConverter}}"
                                   FontSize="{Binding LabelSize}" FontWeight="{Binding LabelWeightStr}">
                            <TextBlock.Margin>
                                <MultiBinding Converter="{StaticResource IconToMarginConverter}">
                                    <Binding Path="Icon"/>
                                    <Binding Path="IsIconLeft"/>
                                </MultiBinding>
                            </TextBlock.Margin>
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource LabelVisibilityConverter}">
                                    <Binding Path="Label"/>
                                    <Binding Path="DataContext.IsCollapsed" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>
                        <TextBlock Grid.Column="{Binding IsIconRight, Converter={StaticResource BoolToStringValueConverter}}"
                                   Grid.Row="0"
                                   Text="{Binding Icon}" 
                                   FontSize="{Binding IconSize}" FontFamily="Segoe Fluent Icons"
                                   FontWeight="{Binding IconWeightStr}"
                                   HorizontalAlignment="{Binding RightIconHorizontalAlignment, Converter={StaticResource ControlHorizontalAlignmentToHorizontalAlignmentConverter}}"
                                   VerticalAlignment="{Binding RightIconVerticalAlignment, Converter={StaticResource ControlVerticalAlignmentToVerticalAlignmentConverter}}"
                                   Visibility="{Binding IsIconRight, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </Button>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
