<UserControl x:Class="DinaGameEngine.Views.Shared.ValidatedLabeledTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:shared="clr-namespace:DinaGameEngine.Views.Shared"
             xmlns:converters="clr-namespace:DinaGameEngine.Converters"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>
    <StackPanel>
        <shared:LabeledTextBox Label="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Text="{Binding Text, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               IsKeyFocused="{Binding IsKeyFocused, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        <TextBlock Text="{Binding ErrorMessage, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Foreground="OrangeRed"
                   FontSize="11"
                   Margin="0,0,0,8"
                   Visibility="{Binding ErrorMessage, RelativeSource={RelativeSource AncestorType=UserControl},
                                Converter={StaticResource StringToVisibilityConverter}}"/>
    </StackPanel>
</UserControl>