<Window x:Class="DinaGameEngine.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DinaGameEngine.Views"
        xmlns:usercontrols="clr-namespace:DinaGameEngine.Views.UserControls"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding MainMenuFileNewProjectCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding MainMenuFileLoadCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding MainMenuFileSaveCommand}"/>
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding MainMenuFileCloseCommand}"/>
        <KeyBinding Key="Q" Modifiers="Ctrl" Command="{Binding MainMenuFileQuitCommand}"/>
    </Window.InputBindings>
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Grid.ColumnSpan="5">
            <usercontrols:MainMenuView />
        </DockPanel>
        
        
    </Grid>
</Window>
