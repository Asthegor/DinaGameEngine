<local:DinaWindow x:Class="DinaGameEngine.Views.MainWindow"
        xmlns:local="clr-namespace:DinaGameEngine.Themes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:project="clr-namespace:DinaGameEngine.Views.Project"
        xmlns:shared="clr-namespace:DinaGameEngine.Views.Shared"
        xmlns:editors="clr-namespace:DinaGameEngine.Views.Project.Editors"
        xmlns:comps="clr-namespace:DinaGameEngine.Views.Project.Components"
        xmlns:vmProj="clr-namespace:DinaGameEngine.ViewModels.Project"
        xmlns:vmEditors="clr-namespace:DinaGameEngine.ViewModels.Project.Editors"
        xmlns:vmComps="clr-namespace:DinaGameEngine.ViewModels.Project.Components"
        xmlns:enums="clr-namespace:DinaGameEngine.Common.Enums;assembly=DinaGameEngine.Common"
        xmlns:converters="clr-namespace:DinaGameEngine.Converters"
        Title="{Binding WindowTitle}" Height="450" Width="800"
        Style="{StaticResource DinaWindowStyle}"
        TitleBarButtons="{x:Static enums:TitleBarButtons.MinimizeMaximizeAndClose}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vmProj:ProjectHomeViewModel}">
            <project:ProjectHomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmEditors:SceneEditorViewModel}">
            <editors:SceneEditorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmEditors:LocalizationEditorViewModel}">
            <editors:LocalizationEditorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmEditors:FontEditorViewModel}">
            <editors:FontEditorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmEditors:ImageEditorViewModel}">
            <editors:ImageEditorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmEditors:AudioEditorViewModel}">
            <editors:AudioEditorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmEditors:ColorEditorViewModel}">
            <editors:ColorEditorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmEditors:InputEditorViewModel}">
            <editors:InputEditorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmEditors:ConfigEditorViewModel}">
            <editors:ConfigEditorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmComps:TextComponentPropertiesViewModel}">
            <comps:ComponentPropertiesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmComps:MenuManagerComponentPropertiesViewModel}">
            <comps:ComponentPropertiesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmComps:MenuTitleComponentPropertiesViewModel}">
            <comps:ComponentPropertiesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmComps:MenuItemComponentPropertiesViewModel}">
            <comps:ComponentPropertiesView/>
        </DataTemplate>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <local:DinaWindow.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding MainMenuFileNewProjectCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding MainMenuFileLoadProjectCommand }"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding MainMenuFileSaveProjectCommand}"/>
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding MainMenuFileCloseViewCommand}"/>
        <KeyBinding Key="Q" Modifiers="Ctrl" Command="{Binding MainMenuFileQuitCommand}"/>
    </local:DinaWindow.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu -->
        <DockPanel Grid.Row="0" Grid.ColumnSpan="5">
            <shared:MainMenuView />
        </DockPanel>

        <!-- Barre d'onglets -->
        <shared:TabBarView Grid.Row="1"
                           Visibility="{Binding HasMultipleViews, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Fenêtre principale -->
        <ContentControl Grid.Row="2" Content="{Binding CurrentViewModel}"/>

        <!-- Barre d'état / à faire -->
    </Grid>
</local:DinaWindow>
