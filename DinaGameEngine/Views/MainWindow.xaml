<local:DinaWindow x:Class="DinaGameEngine.Views.MainWindow"
        xmlns:local="clr-namespace:DinaGameEngine.Themes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:usercontrols="clr-namespace:DinaGameEngine.Views.UserControls"
        xmlns:vm="clr-namespace:DinaGameEngine.ViewModels"
        xmlns:enums="clr-namespace:DinaGameEngine.Common.Enums;assembly=DinaGameEngine.Common"
        Title="{Binding WindowTitle}" Height="450" Width="800"
        Style="{StaticResource DinaWindowStyle}"
        TitleBarButtons="{x:Static enums:TitleBarButtons.MinimizeMaximizeAndClose}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ProjectHomeViewModel}">
            <usercontrols:ProjectHomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SceneEditorViewModel}">
            <usercontrols:SceneEditorView/>
        </DataTemplate>
    </Window.Resources>
    <local:DinaWindow.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding MainMenuFileNewProjectCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding MainMenuFileLoadCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding MainMenuFileSaveCommand}"/>
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding MainMenuFileCloseCommand}"/>
        <KeyBinding Key="Q" Modifiers="Ctrl" Command="{Binding MainMenuFileQuitCommand}"/>
    </local:DinaWindow.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu -->
        <DockPanel Grid.Row="0" Grid.ColumnSpan="5">
            <usercontrols:MainMenuView />
        </DockPanel>


        <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}"/>

        <!-- Barre d'état -->
    </Grid>
</local:DinaWindow>
