<local:DinaWindow x:Class="DinaGameEngine.Views.DialogWindow"
        xmlns:local="clr-namespace:DinaGameEngine.Themes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:usercontrols="clr-namespace:DinaGameEngine.Views.UserControls"
        xmlns:ext="clr-namespace:DinaGameEngine.Extensions"
        xmlns:enums="clr-namespace:DinaGameEngine.Common.Enums;assembly=DinaGameEngine.Common"
        Title="{Binding Title}" Height="220" Width="480" 
        Style="{StaticResource DinaWindowStyle}"
        TitleBarButtons="{x:Static enums:TitleBarButtons.CloseOnly}"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!--Contenu de la fenêtre-->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16" VerticalAlignment="Center">
            <ContentControl Width="40" Height="40" Margin="16">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Icon}" Value="{x:Static enums:DialogIcon.Info}">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <Border Width="40" Height="40" CornerRadius="20"
                                                    Background="#2196F3">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontSize="20" Foreground="White" FontWeight="Bold"
                                                           Text="i"/>
                                        </Border>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Icon}" Value="{x:Static enums:DialogIcon.Warning}">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <Border Width="40" Height="40" CornerRadius="20"
                                                    Background="#FF9800">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontSize="20" Foreground="White" FontWeight="Bold"
                                                           Text="!"/>
                                        </Border>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Icon}" Value="{x:Static enums:DialogIcon.Error}">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <Border Width="40" Height="40" CornerRadius="20"
                                                    Background="#F44336">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontSize="20" Foreground="White" FontWeight="Bold"
                                                           Text="✕"/>
                                        </Border>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Icon}" Value="{x:Static enums:DialogIcon.Success}">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <Border Width="40" Height="40" CornerRadius="20"
                                                    Background="#4CAF50">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontSize="20" Foreground="White" FontWeight="Bold"
                                                           Text="✓"/>
                                        </Border>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Icon}" Value="{x:Static enums:DialogIcon.None}">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <ContentControl/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
            <TextBlock Text="{Binding Message}" Margin="16,0,0,0"
                           FontSize="14" TextWrapping="Wrap" VerticalAlignment="Center"/>
        </StackPanel>

        <!--Footer -->
        <Grid Grid.Row="1" Margin="16,8,16,16" x:Name="GroupOK">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Buttons}" Value="{x:Static enums:DialogButtons.OK}">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Margin="8,0,0,0"
                        Width="120" HorizontalAlignment="Center"
                        Command="{Binding ConfirmCommand}"
                        Style="{StaticResource GhostFooterButton}"
                        Background="DarkViolet"
                        BorderBrush="DarkViolet"
                        Foreground="White"
                        Tag="#532E80"
                        Content="{ext:Translate Key=Dialog_OK}"/>
        </Grid>

        <Grid Grid.Row="1" Margin="16,8,16,16" x:Name="GroupOKCancel">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Buttons}" Value="{x:Static enums:DialogButtons.OKCancel}">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Margin="0,0,8,0"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource GhostFooterButton}"
                        BorderBrush="OrangeRed"
                        Foreground="OrangeRed"
                        Tag="#FFECB3"
                        Content="{ext:Translate Key=Dialog_Cancel}"/>

            <Button Grid.Column="1" Margin="8,0,0,0"
                        Command="{Binding ConfirmCommand}"
                        Style="{StaticResource GhostFooterButton}"
                        Background="DarkViolet"
                        BorderBrush="DarkViolet"
                        Foreground="White"
                        Tag="#532E80"
                        Content="{ext:Translate Key=Dialog_OK}"/>
        </Grid>

        <Grid Grid.Row="1" Margin="16,8,16,16" x:Name="GroupYesNo">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Buttons}" Value="{x:Static enums:DialogButtons.YesNo}">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Margin="0,0,8,0"
                        Command="{Binding NoCommand}"
                        Style="{StaticResource GhostFooterButton}"
                        BorderBrush="OrangeRed"
                        Foreground="OrangeRed"
                        Tag="#FFECB3"
                        Content="{ext:Translate Key=Dialog_No}"/>

            <Button Grid.Column="1" Margin="8,0,0,0"
                        Command="{Binding YesCommand}"
                        Style="{StaticResource GhostFooterButton}"
                        Background="DarkViolet"
                        BorderBrush="DarkViolet"
                        Foreground="White"
                        Tag="#532E80"
                        Content="{ext:Translate Key=Dialog_Yes}"/>
        </Grid>
    </Grid>
</local:DinaWindow>