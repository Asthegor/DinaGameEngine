<local:DinaWindow x:Class="DinaGameEngine.Views.DialogWindow"
        xmlns:local="clr-namespace:DinaGameEngine.Themes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:DinaGameEngine.Views.UserControls.Shared"
        xmlns:ext="clr-namespace:DinaGameEngine.Extensions"
        xmlns:enums="clr-namespace:DinaGameEngine.Common.Enums;assembly=DinaGameEngine.Common"
        Title="{Binding Title}" Height="220" Width="480" 
        Style="{StaticResource DinaWindowStyle}"
        TitleBarButtons="{x:Static enums:TitleBarButtons.CloseOnly}"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!--Contenu de la fenêtre-->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16" VerticalAlignment="Center">
            <ContentControl Width="40" Height="40" Margin="16">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Icon}" Value="{x:Static enums:DialogIcon.Info}">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="40" Foreground="#2196F3" FontWeight="Bold"
                                                   Text="&#xE946;" FontFamily="Segoe Fluent Icons"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Icon}" Value="{x:Static enums:DialogIcon.Warning}">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="40" Foreground="#FF9800" FontWeight="Bold"
                                                   Text="&#xE7BA;" FontFamily="Segoe Fluent Icons"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Icon}" Value="{x:Static enums:DialogIcon.Error}">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="40" Foreground="#F44336" FontWeight="Bold"
                                                   Text="&#xE783;" FontFamily="Segoe Fluent Icons"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Icon}" Value="{x:Static enums:DialogIcon.Success}">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="40" Foreground="#4CAF50" FontWeight="Bold"
                                                   Text="&#xE73E;" FontFamily="Segoe Fluent Icons"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Icon}" Value="{x:Static enums:DialogIcon.None}">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <ContentControl/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
            <TextBlock Text="{Binding Message}" Margin="16,0,0,0"
                           FontSize="14" TextWrapping="Wrap" VerticalAlignment="Center"/>
        </StackPanel>

        <!--Footer -->
        <shared:ButtonBarView Grid.Row="1" 
                                    DataContext="{Binding FooterButtons}" 
                                    Margin="8,4,8,8"/>
    </Grid>
</local:DinaWindow>