<UserControl x:Class="DinaGameEngine.Views.Project.Components.ColorSliderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DinaGameEngine.Views.Project.Components"
             mc:Ignorable="d" d:DesignWidth="800" Height="40">
    <Grid Margin="0,0,0,2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="30"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
                   Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Foreground="#AAAAAA"/>
        <Slider Grid.Column="1"
                Minimum="0" Maximum="255"
                Value="{Binding ColorValue, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Margin="5,0,5,0"/>
        <TextBox Grid.Column="2"
                 Foreground="#AAAAAA"
                 Text="{Binding ColorValue, UpdateSourceTrigger=PropertyChanged,
                        Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
    </Grid>

</UserControl>
