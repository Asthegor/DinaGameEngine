<UserControl x:Class="DinaGameEngine.Views.Project.Cards.ComponentCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DinaGameEngine.Views.Project.Cards"
             xmlns:shared="clr-namespace:DinaGameEngine.Views.Shared"
             xmlns:conv="clr-namespace:DinaGameEngine.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/CardItem.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>
        <Border CornerRadius="6" Height="36" Margin="0,1,0,1">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardItemBorderStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="BorderBrush" Value="DarkViolet"/>
                            <Setter Property="Background" Value="#1ABF28FF"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid Background="Transparent">
                <Grid.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding SelectCommand}"/>
                </Grid.InputBindings>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Margin="4,0,0,0"
                        Content="{Binding ExpandIcon}"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="14"
                        Command="{Binding ToggleExpandCommand}"
                        Style="{DynamicResource GhostFooterButton}"
                        Width="28" Height="28"
                        Visibility="{Binding HasItems, Converter={StaticResource BoolToVisibility}}"/>

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0">
                    <Run Text="{Binding Key, Mode=OneWay}"
                         Foreground="DimGray" FontWeight="SemiBold"/>
                    <Run Text=" (" Foreground="Gray" FontSize="11"/>
                    <Run Text="{Binding Type, Mode=OneWay}"
                         FontFamily="Consolas" FontSize="11" Foreground="Gray"/>
                    <Run Text=")" Foreground="Gray" FontSize="11"/>
                </TextBlock>

                <Button Grid.Column="2"
                        Margin="4,0,4,0"
                        Content="{Binding DeleteIcon}"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="14"
                        Command="{Binding DeleteCommand}"
                        Style="{DynamicResource GhostFooterButton}"
                        Width="28" Height="28"
                        BorderBrush="OrangeRed"
                        Foreground="OrangeRed"
                        Tag="#FFECB3"/>
            </Grid>
        </Border>

        <StackPanel x:Name="SubItems" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">

            <!-- Header Titres -->
            <shared:ExpandedListHeader Margin="24,0,0,0"
                                       Header="{Binding TitlesHeader}"
                                       ToggleExpandCommand="{Binding ToggleTitlesExpandCommand}"
                                       AddCommand="{Binding AddTitleCommand}"/>

            <!-- Liste Titres -->
            <StackPanel Visibility="{Binding IsTitlesExpanded, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl ItemsSource="{Binding MenuTitles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <local:MenuManagerSubCardView/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Separator Margin="24,2,4,2"/>

            <!-- Header Items -->
            <shared:ExpandedListHeader Margin="24,0,0,0"
                                       Header="{Binding ItemsHeader}"
                                       ToggleExpandCommand="{Binding ToggleItemsExpandCommand}"
                                       AddCommand="{Binding AddItemCommand}"/>

            <!-- Liste Items -->
            <StackPanel Visibility="{Binding IsItemsExpanded, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl ItemsSource="{Binding MenuItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <local:MenuManagerSubCardView/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

        </StackPanel>
        
    </StackPanel>
</UserControl>