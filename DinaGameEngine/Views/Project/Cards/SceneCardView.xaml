<UserControl x:Class="DinaGameEngine.Views.Project.Cards.SceneCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DinaGameEngine.Views.Project.Cards"
             xmlns:shared="clr-namespace:DinaGameEngine.Views.Shared"
             xmlns:ext="clr-namespace:DinaGameEngine.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="150" d:DesignWidth="600">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/CardItem.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource CardItemBorderStyle}" CornerRadius="10" Padding="5" Margin="0,2,0,2">

        <Grid Background="Transparent">
            <Grid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenCommand}"/>
                <MouseBinding MouseAction="LeftClick" Command="{Binding SelectCommand}"/>
            </Grid.InputBindings>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding Icon}"
                       FontFamily="Segoe Fluent Icons"
                       FontSize="32"
                       Margin="0,0,8,0"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <Grid Grid.Column="1" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="{Binding Name, Mode=OneWay}" Foreground="DimGray" FontWeight="SemiBold"/>
                        <Run Text=" (" Foreground="Gray" FontSize="11"/>
                        <Run Text="{Binding Key, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="Gray"/>
                        <Run Text=")" Foreground="Gray" FontSize="11"/>
                    </TextBlock>

                    <Border CornerRadius="4" Background="#CECBF6" Padding="4,1" Margin="6,0,0,0" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStartup}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{ext:Translate Key=SceneCard_StartupBadge}"
                                   Foreground="#3C3489" FontSize="11"/>
                    </Border>

                    <Border CornerRadius="4" Padding="4,1" Margin="6,0,0,0" VerticalAlignment="Center"
                            Cursor="Hand" BorderThickness="0.5" BorderBrush="Gray">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding SetAsStartupCommand}"/>
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsStartup}" Value="False"/>
                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border, AncestorLevel=2}}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{ext:Translate Key=SceneCard_SetStartupBadge}"
                                   Foreground="Gray" FontSize="11"/>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Row="1" VerticalAlignment="Center">
                    <Run Text="{ext:Translate Key=MainWindow_Scene_Components}" Foreground="DimGray" FontWeight="SemiBold"/>
                    <Run Text="{Binding ComponentsCount, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="Gray"/>
                </TextBlock>
            </Grid>

            <shared:ButtonBarView Grid.Column="2" HorizontalAlignment="Right"
                                  DataContext="{Binding NavigationButtons}" 
                                  Margin="8,4,8,8"/>
        </Grid>
    </Border>
</UserControl>
