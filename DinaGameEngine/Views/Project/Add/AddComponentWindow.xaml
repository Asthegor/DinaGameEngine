<local:DinaWindow x:Class="DinaGameEngine.Views.Project.Add.AddComponentWindow"
        xmlns:local="clr-namespace:DinaGameEngine.Themes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:DinaGameEngine.Views.Shared"
        xmlns:enums="clr-namespace:DinaGameEngine.Common.Enums;assembly=DinaGameEngine.Common"
        xmlns:ext="clr-namespace:DinaGameEngine.Extensions"
        xmlns:converters="clr-namespace:DinaGameEngine.Converters"
        xmlns:comps="clr-namespace:DinaGameEngine.Views.Project.Components"
        xmlns:vmAdd="clr-namespace:DinaGameEngine.ViewModels.Project.Add"
        Title="{Binding WindowTitle}"
        SizeToContent="Height" Width="400"
        Style="{StaticResource DinaWindowStyle}"
        TitleBarButtons="{x:Static enums:TitleBarButtons.CloseOnly}"
        WindowStartupLocation="CenterOwner"
        FocusManager.FocusedElement="{Binding ElementName=KeyTextBox}">
    <Window.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <DataTemplate DataType="{x:Type vmAdd:AddTextComponentViewModel}">
            <comps:AddTextComponentPropertiesView/>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,8"
                   Text="{ext:Translate Key=AddComponent_Key_Label}"
                   Style="{DynamicResource FieldLabelStyle}"/>

        <TextBox Grid.Row="1" Margin="0,0,0,4"
                 Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                 Style="{DynamicResource ModernTextBoxStyle}"
                 GotFocus="KeyTextBox_GotFocus"
                 LostFocus="KeyTextBox_LostFocus"
                 x:Name="KeyTextBox"/>

        <TextBlock Grid.Row="2"
                   Text="{Binding KeyErrorMessage}"
                   Foreground="OrangeRed"
                   FontSize="11"
                   Margin="0,0,0,8"
                   Visibility="{Binding KeyErrorMessage, 
                                Converter={StaticResource StringToVisibilityConverter}}"/>

        <ContentControl Grid.Row="3"
                        Content="{Binding SpecificProperties}"
                        Margin="0,0,0,8"/>

        <shared:ButtonBarView Grid.Row="4"
                              DataContext="{Binding FooterButtons}"
                              Margin="0,4,0,0"/>
    </Grid>
</local:DinaWindow>