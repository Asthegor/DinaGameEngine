<local:DinaWindow x:Class="DinaGameEngine.Views.Project.Add.AddComponentWindow"
        xmlns:local="clr-namespace:DinaGameEngine.Themes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:DinaGameEngine.Views.Shared"
        xmlns:enums="clr-namespace:DinaGameEngine.Common.Enums;assembly=DinaGameEngine.Common"
        xmlns:ext="clr-namespace:DinaGameEngine.Extensions"
        xmlns:converters="clr-namespace:DinaGameEngine.Converters"
        xmlns:add="clr-namespace:DinaGameEngine.Views.Project.Add"
        xmlns:vmAdd="clr-namespace:DinaGameEngine.ViewModels.Project.Add"
        Title="{Binding WindowTitle}"
        SizeToContent="Height" Width="400"
        Style="{StaticResource DinaWindowStyle}"
        TitleBarButtons="{x:Static enums:TitleBarButtons.CloseOnly}"
        WindowStartupLocation="CenterOwner"
        >
        <!--FocusManager.FocusedElement="{Binding ElementName=KeyTextBox}"-->
    <Window.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <DataTemplate DataType="{x:Type vmAdd:AddTextComponentViewModel}">
            <add:AddTextComponentView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmAdd:AddMenuManagerComponentViewModel}">
            <add:AddMenuManagerComponentView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmAdd:AddMenuItemComponentViewModel}">
            <add:AddMenuItemComponentView/>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <shared:ValidatedLabeledTextBox x:Name="KeyTextBox" Grid.Row="0"
                                        Label="{ext:Translate Key=Component_Key_Label}"
                                        Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                        ErrorMessage="{Binding KeyErrorMessage}"
                                        IsKeyFocused="{Binding IsKeyFocused, Mode=TwoWay}"/>

        <ContentControl Grid.Row="1"
                        Content="{Binding SpecificProperties}"
                        Margin="0,0,0,8"/>

        <shared:ButtonBarView Grid.Row="2"
                              DataContext="{Binding FooterButtons}"
                              Margin="0,4,0,0"/>
    </Grid>
</local:DinaWindow>