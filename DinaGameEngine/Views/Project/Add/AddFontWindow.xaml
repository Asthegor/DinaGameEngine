<local:DinaWindow x:Class="DinaGameEngine.Views.Project.Add.AddFontWindow"
        xmlns:local="clr-namespace:DinaGameEngine.Themes"             
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:DinaGameEngine.Views.Shared"
        xmlns:comps="clr-namespace:DinaGameEngine.Views.Project.Components"
        xmlns:enums="clr-namespace:DinaGameEngine.Common.Enums;assembly=DinaGameEngine.Common"
        xmlns:ext="clr-namespace:DinaGameEngine.Extensions"
        xmlns:converters="clr-namespace:DinaGameEngine.Converters"
        Title="{Binding WindowTitle}" Height="450" Width="800"
        Style="{StaticResource DinaWindowStyle}"
        TitleBarButtons="{x:Static enums:TitleBarButtons.CloseOnly}"
        WindowStartupLocation="CenterScreen"
        FocusManager.FocusedElement="{Binding ElementName=KeyTextBox}">
    <Window.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Margin="0,0,0,8"
                       Text="{ext:Translate Key=AddFont_Key_Label}"
                       Style="{DynamicResource FieldLabelStyle}"/>

            <TextBox Grid.Row="1" Margin="0,0,0,8" 
                     Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                     Style="{DynamicResource ModernTextBoxStyle}"
                     GotFocus="KeyTextBox_GotFocus"
                     LostFocus="KeyTextBox_LostFocus"
                     x:Name="KeyTextBox"/>

            <TextBlock Grid.Row="2" 
                       Text="{Binding KeyErrorMessage}"
                       Foreground="OrangeRed"
                       FontSize="11"
                       Margin="0,0,0,8"
                       Visibility="{Binding KeyErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

            <TextBlock Grid.Row="3" Margin="0,0,0,8"
                       Text="{ext:Translate Key=AddFont_TtfFile_Label}"
                       Style="{DynamicResource FieldLabelStyle}"/>
            
            <Grid Grid.Row="4" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <ComboBox Grid.Column="0"
                          x:Name="TtfComboBox"
                          ItemsSource="{Binding NamedItems}"
                          SelectedItem="{Binding SelectedNamedItem, Mode=TwoWay}"
                          DisplayMemberPath="Name"
                          Height="28"/>
                
                <Button Grid.Column="1" Margin="10,0,0,0"
                        Content="..."
                        Command="{Binding BrowseTtfFileCommand}"
                        Style="{DynamicResource GhostFooterButton}"
                        Height="{Binding ActualHeight, ElementName=TtfComboBox}"
                        Width="28"
                        BorderBrush="DarkViolet" 
                        Foreground="DarkViolet"
                        Tag="#F3E5F5"/>

            </Grid>

            <TextBlock Grid.Row="5" Margin="0,0,0,8"
                       Text="{ext:Translate Key=AddFont_Size_Label}"
                       Style="{DynamicResource FieldLabelStyle}"/>

            <TextBox Grid.Row="6" Margin="0,0,0,8" 
                     Text="{Binding Size, UpdateSourceTrigger=PropertyChanged}"
                     Style="{DynamicResource ModernTextBoxStyle}"/>

            <TextBlock Grid.Row="7" Margin="0,0,0,8"
                       Text="{ext:Translate Key=AddFont_Style_Label}"
                       Style="{DynamicResource FieldLabelStyle}"/>

            <ComboBox Grid.Row="8"
                      ItemsSource="{Binding AvailableStyles}"
                      SelectedItem="{Binding Style, Mode=TwoWay}"
                      Margin="0,0,0,8"/>

            <TextBlock Grid.Row="9" Margin="0,0,0,8"
                       Text="{ext:Translate Key=AddFont_Spacing_Label}"
                       Style="{DynamicResource FieldLabelStyle}"/>

            <TextBox Grid.Row="10" Margin="0,0,0,8" 
                     Text="{Binding Spacing, UpdateSourceTrigger=PropertyChanged}"
                     Style="{DynamicResource ModernTextBoxStyle}"/>

        </Grid>

        <shared:ButtonBarView Grid.Row="1" 
                              DataContext="{Binding FooterButtons}" 
                              Margin="8,4,8,8"/>
    </Grid>
</local:DinaWindow>
