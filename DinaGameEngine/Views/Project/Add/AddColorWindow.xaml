<local:DinaWindow x:Class="DinaGameEngine.Views.Project.Add.AddColorWindow"
        xmlns:local="clr-namespace:DinaGameEngine.Themes"             
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:DinaGameEngine.Views.Shared"
        xmlns:comps="clr-namespace:DinaGameEngine.Views.Project.Components"
        xmlns:enums="clr-namespace:DinaGameEngine.Common.Enums;assembly=DinaGameEngine.Common"
        xmlns:ext="clr-namespace:DinaGameEngine.Extensions"
        xmlns:converters="clr-namespace:DinaGameEngine.Converters"
        Title="{Binding WindowTitle}" Height="450" Width="800"
        Style="{StaticResource DinaWindowStyle}"
        TitleBarButtons="{x:Static enums:TitleBarButtons.CloseOnly}"
        WindowStartupLocation="CenterScreen"
        FocusManager.FocusedElement="{Binding ElementName=KeyTextBox}">
    <Window.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">

            <shared:ValidatedLabeledTextBox x:Name="KeyTextBox"
                                            Label="{ext:Translate Key=AddColor_Key_Label}"
                                            Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                            ErrorMessage="{Binding KeyErrorMessage}"
                                            IsKeyFocused="{Binding IsKeyFocused, Mode=TwoWay}"/>

            <comps:ColorPickerView Label="{ext:Translate Key=AddColor_ColorPicker_Label}"
                                   SelectedColor="{Binding PreviewColor, Mode=TwoWay}"
                                   SelectedNamedColor="{Binding SelectedNamedItem, Mode=TwoWay}"
                                   NamedColors="{Binding NamedItems, Mode=OneWay}"/>
        </StackPanel>

        <shared:ButtonBarView Grid.Row="1" 
                              DataContext="{Binding FooterButtons}" 
                              Margin="8,4,8,8"/>
    </Grid>
</local:DinaWindow>