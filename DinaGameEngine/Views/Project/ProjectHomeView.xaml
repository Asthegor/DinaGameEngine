<UserControl x:Class="DinaGameEngine.Views.Project.ProjectHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DinaGameEngine.Views.Project"
             xmlns:shared="clr-namespace:DinaGameEngine.Views.Shared"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Vertical" Grid.Column="0">
            <Button Content="{Binding CollapsedIcon}"
                    FontFamily="Segoe Fluent Icons"
                    Foreground="DarkViolet"
                    Background="Transparent"
                    HorizontalAlignment="Right"
                    FontSize="16"
                    BorderThickness="0"
                    Command="{Binding ToggleNavigationCommand}"/>
            <shared:ButtonBarView DataContext="{Binding NavigationButtons}"/>
        </StackPanel>

        <ScrollViewer Grid.Column="1" Background="Transparent" Margin="16">
            <ItemsControl ItemsSource="{Binding Scenes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <local:SceneCardView />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>

</UserControl>
