<local:DinaWindow x:Class="DinaGameEngine.Views.AddSceneWindow"
        xmlns:local="clr-namespace:DinaGameEngine.Themes"             
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ext="clr-namespace:DinaGameEngine.Extensions"
        xmlns:common="clr-namespace:DinaGameEngine.Common;assembly=DinaGameEngine.Common"
        xmlns:usercontrols="clr-namespace:DinaGameEngine.Views.UserControls"
        Title="{ext:Translate Key=AddScene_Title}"
        SizeToContent="Height" Width="400"
        Style="{StaticResource DinaWindowStyle}"
        TitleBarButtons="{x:Static common:TitleBarButtons.CloseOnly}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Margin="0,0,0,8"
                       Text="{ext:Translate Key=SceneName_Label}"
                       Style="{DynamicResource FieldLabelStyle}"
                       />
            <TextBox Grid.Row="1" Margin="0,0,0,8" 
                     Text="{Binding SceneName, UpdateSourceTrigger=PropertyChanged}"
                     Style="{DynamicResource ModernTextBoxStyle}"/>
            <TextBlock Grid.Row="2" Margin="0,0,0,8" 
                       Text="{ext:Translate Key=SceneName_ClassName}"
                       Style="{DynamicResource FieldLabelStyle}"/>
            <TextBlock Grid.Row="3" Margin="0,0,0,8" 
                       Text="{Binding ClassName}"/>
            <TextBlock Grid.Row="4" Margin="0,0,0,8" 
                       Text="{ext:Translate Key=SceneName_Key}"
                       Style="{DynamicResource FieldLabelStyle}"/>
            <TextBlock Grid.Row="5" 
                       Margin="0,0,0,8" 
                       Text="{Binding Key}"/>
        </Grid>
        
        <usercontrols:ButtonBarView Grid.Row="1" 
                                    DataContext="{Binding FooterButtons}" 
                                    Margin="8,4,8,8"/>
    </Grid>
</local:DinaWindow>
