<local:DinaWindow x:Class="DinaGameEngine.Views.LanguageSelectionWindow"
        xmlns:local="clr-namespace:DinaGameEngine.Themes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ext="clr-namespace:DinaGameEngine.Extensions"
        xmlns:common="clr-namespace:DinaGameEngine.Common;assembly=DinaGameEngine.Common"
        xmlns:enums="clr-namespace:DinaGameEngine.Common.Enums;assembly=DinaGameEngine.Common"
        xmlns:shared="clr-namespace:DinaGameEngine.Views.Shared"
        Title="{ext:Translate Key=Language_Title}"
        SizeToContent="Height" Width="400"
        Style="{StaticResource DinaWindowStyle}"
        TitleBarButtons="{x:Static enums:TitleBarButtons.CloseOnly}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Margin="0,0,0,8"
                       Text="{ext:Translate Key=Language_Label}"
                       FontSize="14"/>
            <ComboBox Grid.Row="1" Margin="0,0,0,16"
                      ItemsSource="{Binding Languages}"
                      SelectedItem="{Binding SelectedLanguage}"
                      DisplayMemberPath="Name"/>

        </Grid>
        <shared:ButtonBarView Grid.Row="1" 
                              DataContext="{Binding FooterButtons}" 
                              Margin="8,4,8,8"/>
    </Grid>
</local:DinaWindow>
