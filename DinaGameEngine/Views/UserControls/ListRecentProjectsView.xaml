<UserControl x:Class="DinaGameEngine.Views.UserControls.ListRecentProjectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DinaGameEngine.Views.UserControls"
             xmlns:ext="clr-namespace:DinaGameEngine.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer Grid.Row="0" Background="Transparent">
        <ItemsControl ItemsSource="{Binding ProjectGroups}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Expander Header="{Binding SectionName}"
                              IsExpanded="{Binding IsExpanded}"
                              Margin="4,4,4,0">
                        <ItemsControl ItemsSource="{Binding Projects}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <local:RecentProjectItemView IconPath="{Binding IconPath}"
                                                                 Title="{Binding Name}"
                                                                 Path="{Binding ProjectFolderPath}"
                                                                 LastOpenedAt="{Binding LastOpenedAt, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}"
                                                                 IsPinned="{Binding IsPinned}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
