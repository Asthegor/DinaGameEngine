<UserControl x:Class="DinaGameEngine.Views.UserControls.MarkersListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DinaGameEngine.Views.UserControls"
             xmlns:ext="clr-namespace:DinaGameEngine.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Text="{ext:Translate Key=Markers_FolderPreview}"
                       Margin="0,8,16,0"/>
            <TextBlock Grid.Row="1" 
                       Text="{Binding NewProjectFolderPreview}"
                       Margin="0,4,16,8"
                       FontStyle="Italic"/>
        </Grid>
        
        <Grid Grid.Row="1" Margin="25,0,25,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/> <!-- 40% -->
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="6*"/> <!-- 60% -->
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{ext:Translate Key=Markers_LabelHeader}"/>
            <TextBlock Grid.Column="2" Text="{ext:Translate Key=Markers_ValueHeader}"/>
        </Grid>

        <ScrollViewer Grid.Row="2" Margin="25,0,25,5">
            <ItemsControl ItemsSource="{Binding Markers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <local:MarkerItemView/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <Grid Grid.Row="3" Margin="0,8,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
            Content="{ext:Translate Key=Markers_Previous}"
            Margin="16,0,8,0"
            Command="{Binding GoToNewProjectCommand}"/>
            <Button Grid.Column="1"
            Content="{ext:Translate Key=Markers_Create}"
            Margin="8,0,16,0"
            Command="{Binding ConfirmNewProjectCommand}"/>
        </Grid>
    </Grid>
</UserControl>
