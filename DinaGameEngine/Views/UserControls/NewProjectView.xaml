<UserControl x:Class="DinaGameEngine.Views.UserControls.NewProjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DinaGameEngine.Views.UserControls"
             xmlns:ext="clr-namespace:DinaGameEngine.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{ext:Translate Key=NewProject_Name}"/>
                <TextBox Grid.Row="1" Text="{Binding DataContext.NewProjectName, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </Grid>

            <Grid Grid.Row="1" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{ext:Translate Key=NewProject_Location}"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                         IsReadOnly="True"
                         Text="{Binding DataContext.NewProjectParentFolder, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    <Button Grid.Column="1"
                        Content="{ext:Translate Key=NewProject_Browse}"
                        Command="{Binding DataContext.BrowseFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                </Grid>
            </Grid>
            <Grid Grid.Row="2" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{ext:Translate Key=NewProject_Preview}"/>
                <TextBlock Grid.Row="1" Text="{Binding DataContext.NewProjectFolderPreview, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </Grid>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="1" Margin="0,8,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" 
                    Content="{ext:Translate Key=NewProject_Cancel}"
                    Margin="16,0,8,0"
                    Command="{Binding DataContext.CancelNewProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Button Grid.Column="1"
                    Content="{ext:Translate Key=NewProject_Next}"
                    Margin="8,0,16,0"
                    Command="{Binding DataContext.GoToMarkerValidationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </Grid>

    </Grid>
</UserControl>
