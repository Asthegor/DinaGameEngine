<Window x:Class="DinaGameEngine.Views.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:usercontrols="clr-namespace:DinaGameEngine.Views.UserControls"
        xmlns:ext="clr-namespace:DinaGameEngine.Extensions"
        xmlns:common="clr-namespace:DinaGameEngine.Common;assembly=DinaGameEngine.Common"
        Title="{Binding WindowTitle}" Height="550" Width="900" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E5E5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostFooterButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Tag" Value="#F5F5F5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                        Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}" 
                        CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" 
                      CornerRadius="0" 
                      GlassFrameThickness="0" 
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <!--<Grid Background="Transparent" Margin="1">-->
    <Border x:Name="MainBorder"
                BorderBrush="DarkViolet" 
                BorderThickness="3" 
                CornerRadius="10" 
                Background="White">
        <Grid Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.OpacityMask>
                <VisualBrush>
                    <VisualBrush.Visual>
                        <Border Background="Black" 
                                SnapsToDevicePixels="True"
                                Width="{Binding ActualWidth, ElementName=MainBorder}"
                                Height="{Binding ActualHeight, ElementName=MainBorder}"
                                CornerRadius="8" />
                    </VisualBrush.Visual>
                </VisualBrush>
            </Grid.OpacityMask>

            <!--Barre de titre-->
            <Grid Grid.Row="0" Background="#F8F8F8" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="{Binding WindowTitle}" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" 
                               Foreground="DarkViolet"
                               FontSize="11"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="0" 
                                FontFamily="Marlett" 
                                Style="{StaticResource TitleBarButtonStyle}" 
                                Click="Minimize_Click"/>

                    <Button Content="r" 
                                FontFamily="Marlett" 
                                Style="{StaticResource CloseButtonStyle}" 
                                Click="Close_Click"/>
                </StackPanel>

            </Grid>

            <!--Contenu de la fenêtre-->
            <ContentControl Grid.Row="1" Margin="16">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentState}" Value="{x:Static common:StartupState.RecentProjects}">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <usercontrols:ListRecentProjectsView/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentState}" Value="{x:Static common:StartupState.NewProject}">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <usercontrols:NewProjectView/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentState}"  Value="{x:Static common:StartupState.MarkerValidation}">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <usercontrols:MarkersListView/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>

            <!--Footer -->
            <Grid Grid.Row="2" Margin="16,8,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GhostFooterButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentState}" Value="{x:Static common:StartupState.RecentProjects}">
                                    <Setter Property="BorderBrush" Value="DarkViolet"/>
                                    <Setter Property="Foreground" Value="DarkViolet"/>
                                    <Setter Property="Tag" Value="#F3E5F5"/>
                                    <Setter Property="Command" Value="{Binding GoToNewProjectCommand}"/>
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="+" FontSize="20" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{ext:Translate Key=Startup_NewProject}" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentState}" Value="{x:Static common:StartupState.NewProject}">
                                    <Setter Property="BorderBrush" Value="OrangeRed"/>
                                    <Setter Property="Foreground" Value="OrangeRed"/>
                                    <Setter Property="Tag" Value="#FFECB3"/>
                                    <Setter Property="Command" Value="{Binding CancelNewProjectCommand}"/>
                                    <Setter Property="Content" Value="{ext:Translate Key=NewProject_Cancel}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentState}" Value="{x:Static common:StartupState.MarkerValidation}">
                                    <Setter Property="BorderBrush" Value="OrangeRed"/>
                                    <Setter Property="Foreground" Value="OrangeRed"/>
                                    <Setter Property="Tag" Value="#F5F5F5"/>
                                    <Setter Property="Command" Value="{Binding GoToNewProjectCommand}"/>
                                    <Setter Property="Content" Value="{ext:Translate Key=Markers_Previous}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="1" Margin="8,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GhostFooterButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentState}" Value="{x:Static common:StartupState.RecentProjects}">
                                    <Setter Property="BorderBrush" Value="OrangeRed"/>
                                    <Setter Property="Foreground" Value="OrangeRed"/>
                                    <Setter Property="Tag" Value="#FFECB3"/>
                                    <Setter Property="Command" Value="{Binding OpenProjectCommand}"/>
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📂" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{ext:Translate Key=Startup_Open}" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding CurrentState}" Value="{x:Static common:StartupState.NewProject}">
                                    <Setter Property="BorderBrush" Value="Gray"/>
                                    <Setter Property="Foreground" Value="DimGray"/>
                                    <Setter Property="Tag" Value="#F5F5F5"/>
                                    <Setter Property="Command" Value="{Binding GoToMarkerValidationCommand}"/>
                                    <Setter Property="Content" Value="{ext:Translate Key=NewProject_Next}"/>
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding CurrentState}" Value="{x:Static common:StartupState.NewProject}"/>
                                        <Condition Binding="{Binding IsEnabled, RelativeSource={RelativeSource Self}}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="BorderBrush" Value="DarkViolet"/>
                                    <Setter Property="Background" Value="DarkViolet"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Tag" Value="#532E80"/>
                                </MultiDataTrigger>

                                <DataTrigger Binding="{Binding CurrentState}" Value="{x:Static common:StartupState.MarkerValidation}">
                                    <Setter Property="BorderBrush" Value="Gray"/>
                                    <Setter Property="Foreground" Value="DimGray"/>
                                    <Setter Property="Tag" Value="#F5F5F5"/>
                                    <Setter Property="Command" Value="{Binding ConfirmNewProjectCommand}"/>
                                    <Setter Property="Content" Value="{ext:Translate Key=Markers_Create}"/>
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding CurrentState}" Value="{x:Static common:StartupState.MarkerValidation}"/>
                                        <Condition Binding="{Binding IsEnabled, RelativeSource={RelativeSource Self}}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="BorderBrush" Value="DarkViolet"/>
                                    <Setter Property="Background" Value="DarkViolet"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Tag" Value="#532E80"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
    <!--</Grid>-->
</Window>







